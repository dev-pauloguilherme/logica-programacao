Algoritmo "PERIMETRO_TERRENO"

Var


    largura, comprimento, perimetro: real

Inicio


   escreva ("Digite a largura do terreno:")
   leia (largura)
   escreva ("Digite o comprimento do terreno:")
   leia (comprimento)

   perimetro <- (largura + largura + comprimento + comprimento)
   escreval ("Perimetro do terreno: ", perimetro:8:2)
Fimalgoritmo