Algoritmo "aumentodesalario"

Var

   nome: caractere
   salario: real
   novo_salario: real
   
Inicio


   escreval ("Digite seu nome")
   leia (nome)
   escreval ("Digite seu salario")
   leia (salario)
   escreval
   novo_salario <- salario + (salario *0.20)
   escreval
   escreval ("Funcionario: ", nome)
   escreval ("Novo salario: ", novo_salario)
Fimalgoritmo